# Local macOS build (`npm run tauri build`)
# Copy to `.env` and fill in your values. Do not commit `.env`.
APPLE_ID=
APPLE_PASSWORD=
APPLE_TEAM_ID=
APPLE_SIGNING_IDENTITY=

# GitHub Actions (Repository Settings > Secrets and variables > Actions)
# Register the same values from `.env`, plus the exported signing certificate:
#
# APPLE_CERTIFICATE
#   Base64-encoded `.p12` (Developer ID Application certificate)
#   Example: base64 -i certificate.p12 | pbcopy
# APPLE_CERTIFICATE_PASSWORD
#   Password used when exporting the `.p12` file
#
# APPLE_ID, APPLE_PASSWORD, APPLE_TEAM_ID, APPLE_SIGNING_IDENTITY
#   Same as local `.env`
