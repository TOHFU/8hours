# Optional: Apple Developer Program (paid) signing / notarization
# Not required for local or CI builds. Ad-hoc signing is configured in tauri.conf.json.
#
# Copy to `.env` only when using Developer ID signing locally. Do not commit `.env`.
# APPLE_ID=
# APPLE_PASSWORD=
# APPLE_TEAM_ID=
# APPLE_SIGNING_IDENTITY=
#
# GitHub Actions: Apple secrets are not used by the current release workflow.
